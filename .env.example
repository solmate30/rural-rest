# ============================================================
# rural-rest environment variables
# Copy this file to web/.env.local and fill in your values.
# Never commit .env.local to git.
# ============================================================

# ------------------------------------------------------------
# Database (Turso)
# Get URL and token from: turso db show <db-name> && turso db tokens create <db-name>
# ------------------------------------------------------------
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ------------------------------------------------------------
# Better Auth
# BETTER_AUTH_SECRET: random string (e.g. openssl rand -base64 32)
# BETTER_AUTH_URL: public base URL of the app
# ------------------------------------------------------------
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5173

# ------------------------------------------------------------
# OAuth - Google
# https://console.cloud.google.com/
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------
# OAuth - Kakao
# https://developers.kakao.com/
# ------------------------------------------------------------
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ------------------------------------------------------------
# Cloudinary (image uploads)
# https://cloudinary.com/console
# ------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ------------------------------------------------------------
# AI - Google Gemini (concierge chat)
# https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=

# ------------------------------------------------------------
# DeepL (auto-translation chat)
# https://www.deepl.com/pro#developer — Free plan: 500k chars/month
# ------------------------------------------------------------
DEEPL_API_KEY=

# ------------------------------------------------------------
# Privy (embedded wallet auth)
# https://dashboard.privy.io/ — App Settings > API Keys
# ------------------------------------------------------------
VITE_PRIVY_APP_ID=          # 클라이언트/서버 공용 App ID (브라우저 노출 OK)
PRIVY_APP_ID=               # 서버 전용 App ID (verifyAuthToken 검증용, VITE_ 없는 버전)
PRIVY_APP_SECRET=           # 서버 전용 Secret (getUser 등 API 호출용, 절대 노출 금지)

# ------------------------------------------------------------
# Google Maps (property map display)
# https://console.cloud.google.com/ - Maps JavaScript API
# ------------------------------------------------------------
VITE_GOOGLE_MAPS_API_KEY=

# ------------------------------------------------------------
# LangSmith (LangChain tracing, optional)
# https://smith.langchain.com/
# ------------------------------------------------------------
LANGSMITH_API_KEY=

# ------------------------------------------------------------
# PayPal (card payments — authorize/capture)
# https://developer.paypal.com/dashboard/
# ------------------------------------------------------------
VITE_PAYPAL_CLIENT_ID=          # 클라이언트 ID (VITE_ 필수 - 브라우저에서 사용)
PAYPAL_CLIENT_SECRET=           # 시크릿 키 (서버 전용)
PAYPAL_MODE=sandbox             # sandbox | live

# ------------------------------------------------------------
# Solana — 온체인 설정
# ------------------------------------------------------------
VITE_SOLANA_NETWORK=devnet              # devnet | mainnet-beta
VITE_SOLANA_RPC=                        # RPC 엔드포인트 (Helius 등)
VITE_RWA_PROGRAM_ID=                    # rural-rest-rwa Anchor 프로그램 ID
VITE_DAO_PROGRAM_ID=                    # DAO 프로그램 ID
VITE_USDC_MINT=                         # USDC 민트 주소 (devnet 페이크 또는 mainnet)
VITE_COUNCIL_MINT=                      # Council 토큰 민트 주소
VITE_LOCAL_GOV_WALLET=                  # 지자체 수취 지갑 주소
VITE_OPERATOR_WALLET=                   # 마을운영자 기본 지갑 주소
CRANK_SECRET_KEY=                       # Crank 서버 지갑 비밀키 (서버 전용, 절대 노출 금지)

# ------------------------------------------------------------
# Helius (Solana RPC + Webhook)
# https://dashboard.helius.dev/
# ------------------------------------------------------------
HELIUS_API_KEY=                         # Helius API 키 (RPC + webhook)
HELIUS_WEBHOOK_SECRET=                  # Webhook 서명 검증용 시크릿
WEBHOOK_AUTH_TOKEN=                     # 내부 webhook API 인증 토큰 (서버 전용)

# ------------------------------------------------------------
# GitHub (DAO 거버넌스 — Gist/Issue 연동)
# ------------------------------------------------------------
GITHUB_TOKEN=                           # GitHub Personal Access Token
GITHUB_DAO_REPO=                        # DAO 이슈 저장소 (예: owner/repo)

# ------------------------------------------------------------
# 공공데이터포털 — 건축HUB 건축물대장 API
# https://www.data.go.kr → 건축HUB_건축물대장정보 서비스 신청
# 용도: 숙소 등록 시 주소 → 건물 존재 확인 + 공시 주택가격 자동 조회
# ------------------------------------------------------------
BUILDING_HUB_API_KEY=                   # 건축물대장 API 인증키

# ------------------------------------------------------------
# VWorld (공간정보 오픈플랫폼 — 지도/주소 검색)
# https://www.vworld.kr/dev/v4dv_apikey_s001.do
# ------------------------------------------------------------
VWORLD_API_KEY=                         # VWorld API 인증키

